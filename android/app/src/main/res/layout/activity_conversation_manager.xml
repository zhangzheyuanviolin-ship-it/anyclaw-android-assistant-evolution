<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:id="@+id/tvConversationManagerTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:importantForAccessibility="yes"
        android:text="@string/conversation_manager_title"
        android:textSize="22sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tvConversationManagerSubtitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:importantForAccessibility="yes"
        android:text="@string/conversation_manager_subtitle"
        android:textSize="14sp" />

    <LinearLayout
        android:id="@+id/layoutConversationFilters"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:orientation="horizontal">

        <Spinner
            android:id="@+id/spinnerConversationSource"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:importantForAccessibility="yes" />

        <Button
            android:id="@+id/btnConversationRefresh"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:importantForAccessibility="yes"
            android:text="@string/conversation_refresh" />
    </LinearLayout>

    <ProgressBar
        android:id="@+id/progressConversation"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:indeterminate="true"
        android:visibility="gone" />

    <TextView
        android:id="@+id/tvConversationStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:importantForAccessibility="yes"
        android:text="@string/conversation_loading"
        android:visibility="gone" />

    <ListView
        android:id="@+id/listConversations"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="12dp"
        android:layout_weight="1"
        android:importantForAccessibility="yes" />

</LinearLayout>
