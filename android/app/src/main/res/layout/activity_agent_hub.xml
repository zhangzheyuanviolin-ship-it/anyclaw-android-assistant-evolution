<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#020617"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:id="@+id/tvAgentHubTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/agent_hub_title"
            android:textColor="#E2E8F0"
            android:textSize="24sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvAgentHubSubtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/agent_hub_subtitle"
            android:textColor="#94A3B8"
            android:textSize="14sp" />

        <Button
            android:id="@+id/btnAgentHubOpenClaw"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:minHeight="52dp"
            android:text="@string/agent_hub_openclaw"
            android:textAllCaps="false" />

        <Button
            android:id="@+id/btnAgentHubCodex"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:minHeight="52dp"
            android:text="@string/agent_hub_codex"
            android:textAllCaps="false" />

        <Button
            android:id="@+id/btnAgentHubClaude"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:minHeight="52dp"
            android:text="@string/agent_hub_claude"
            android:textAllCaps="false" />

        <Button
            android:id="@+id/btnAgentHubHermes"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:minHeight="52dp"
            android:text="@string/agent_hub_hermes"
            android:textAllCaps="false" />

        <Button
            android:id="@+id/btnAgentHubPermissionCenter"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:minHeight="52dp"
            android:text="@string/agent_hub_permission_center"
            android:textAllCaps="false" />

    </LinearLayout>
</ScrollView>
