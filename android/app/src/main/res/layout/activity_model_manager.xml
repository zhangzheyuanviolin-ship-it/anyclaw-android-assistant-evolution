<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:id="@+id/tvModelManagerTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:importantForAccessibility="yes"
        android:text="@string/model_manager_title"
        android:textSize="22sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tvModelManagerSubtitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:importantForAccessibility="yes"
        android:text="@string/model_manager_subtitle"
        android:textSize="14sp" />

    <LinearLayout
        android:id="@+id/layoutModelActions"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:orientation="horizontal">

        <Button
            android:id="@+id/btnModelRefresh"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:importantForAccessibility="yes"
            android:text="@string/model_manager_refresh" />
    </LinearLayout>

    <TextView
        android:id="@+id/tvCurrentModel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:importantForAccessibility="yes"
        android:text="@string/model_manager_current_prefix" />

    <ProgressBar
        android:id="@+id/progressModel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:indeterminate="true"
        android:visibility="gone" />

    <TextView
        android:id="@+id/tvModelStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:importantForAccessibility="yes"
        android:text="@string/model_manager_loading"
        android:visibility="gone" />

    <ListView
        android:id="@+id/listModels"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="12dp"
        android:layout_weight="1"
        android:importantForAccessibility="yes" />

</LinearLayout>
