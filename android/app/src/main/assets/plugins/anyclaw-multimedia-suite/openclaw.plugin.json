{
  "id": "anyclaw-multimedia-suite",
  "name": "AnyClaw Multimedia Suite",
  "description": "Android-friendly multimedia helper tools for ffmpeg/ffprobe and dependency bootstrap.",
  "version": "1.0.0",
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "timeoutSeconds": {
        "type": "number",
        "minimum": 10,
        "maximum": 300
      },
      "workspaceRoot": {
        "type": "string"
      },
      "allowInstall": {
        "type": "boolean"
      },
      "allowExec": {
        "type": "boolean"
      }
    }
  }
}
