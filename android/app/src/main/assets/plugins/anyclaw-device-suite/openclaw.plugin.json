{
  "id": "anyclaw-device-suite",
  "name": "Pocket Lobster Device Suite",
  "description": "Shizuku-first Android device automation tools: screenshot, UI coordinates, tap/swipe/text/keyevent, and app navigation.",
  "version": "1.1.0",
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "timeoutSeconds": {
        "type": "number",
        "minimum": 5,
        "maximum": 120
      },
      "screenshotDir": {
        "type": "string"
      },
      "uiDumpPath": {
        "type": "string"
      },
      "maxUiNodes": {
        "type": "number",
        "minimum": 20,
        "maximum": 400
      },
      "inputImePriority": {
        "type": "array",
        "items": {
          "type": "string"
        }
      },
      "inputVerifyReadback": {
        "type": "boolean"
      }
    }
  }
}
