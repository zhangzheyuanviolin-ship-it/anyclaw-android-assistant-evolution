{
  "id": "anyclaw-search-suite",
  "name": "AnyClaw Search Suite",
  "description": "Free multi-source web search, web visit and HTTP tools for AnyClaw mobile.",
  "version": "1.3.1",
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "timeoutSeconds": {
        "type": "number",
        "minimum": 5,
        "maximum": 120
      },
      "maxResults": {
        "type": "number",
        "minimum": 1,
        "maximum": 10
      },
      "maxChars": {
        "type": "number",
        "minimum": 1000,
        "maximum": 80000
      },
      "userAgent": {
        "type": "string"
      },
      "tavilyApiKey": {
        "type": "string"
      },
      "tavilyBaseUrl": {
        "type": "string"
      }
    }
  }
}
